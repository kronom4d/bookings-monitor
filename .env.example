# =============================================================================
# Microsoft Bookings Monitor — Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Full URL of the Microsoft Bookings calendar to monitor.
# Example: https://outlook.office365.com/book/YourOrg@tenant.onmicrosoft.com/
BOOKING_URL=

# -----------------------------------------------------------------------------
# Optional — General
# -----------------------------------------------------------------------------

# Human-readable label used in notification messages.
BOOKING_NAME=Appointment

# Locale that matches the language of the Outlook calendar UI.
# This controls month names used for calendar navigation.
# Examples: en-US, de-DE, fr-FR
CALENDAR_LOCALE=en-US

# Title attribute of the "next month" navigation button in the Bookings UI.
# Depends on the Outlook tenant language.
# English: "Next"  |  German: "Nächster Monat"  |  French: "Mois suivant"
CALENDAR_NEXT_MONTH_TITLE=Next

# How often to check the calendar (in minutes).
CHECK_INTERVAL_MINUTES=10

# How often to send a heartbeat status message (in hours).
STATUS_INTERVAL_HOURS=24

# -----------------------------------------------------------------------------
# Optional — Telegram notifications
# Leave blank to disable Telegram.
# -----------------------------------------------------------------------------

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Optional — ntfy notifications (https://ntfy.sh)
# Leave blank to disable ntfy.
# -----------------------------------------------------------------------------

# Base URL of your ntfy instance (self-hosted or ntfy.sh).
NTFY_URL=http://localhost:2586

# ntfy topic for important alerts (slot found, errors).
NTFY_TOPIC=

# ntfy topic for verbose debug logs.
NTFY_TOPIC_LOGGING=

# Basic auth credentials (leave blank if your ntfy instance is open).
NTFY_USER=
NTFY_PASSWORD=
